    <R2><Fd label="Tipo de vehículo" req><Si value={d.tipo_veh} onChange={function(v){u("tipo_veh",v)}} options={TIPO_VEH}/></Fd><Fd label="Fecha inspección CEDI" req><Ti type="date" value={d.fecha_insp} onChange={function(v){u("fecha_insp",v)}}/></Fd></R2>
    <Fd label="Inventario conforme" req><Ps options={["SI","NO"]} selected={d.inv_conf} onChange={function(v){u("inv_conf",v)}}/></Fd>
    <SB title="🔍 Inspección por tipo de producto">
      <Fd label="Contenedores"><Ps options={IC} selected={d.i_cont} onChange={function(v){u("i_cont",v)}} multi={true}/></Fd>
      <Fd label="Ganchos"><Ps options={IG} selected={d.i_gan} onChange={function(v){u("i_gan",v)}} multi={true}/></Fd>
      <Fd label="Confección"><Ps options={ICF} selected={d.i_conf} onChange={function(v){u("i_conf",v)}} multi={true}/></Fd>
