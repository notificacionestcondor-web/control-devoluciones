    <Fd label="Cantidades recibidas"><QF productos={PRODUCTOS} data={d} onChange={s}/></Fd>
    <Fd label="Fotos" req hint="Hasta 5 archivos (PDF o imagen, máx 10 MB c/u)"><input type="file" multiple accept="image/*,.pdf" style={Object.assign({},bI,{padding:"8px 12px",cursor:"pointer"})}/></Fd>
    <Fd label="Firmas realizadas" req><Ps options={["SI","NO"]} selected={d.firmas} onChange={function(v){u("firmas",v)}}/></Fd>
