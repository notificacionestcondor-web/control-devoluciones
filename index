/* ═════ APP PRINCIPAL ═════ */
function App(){
  const[active,setActive]=useState(0);
  const[data,setData]=useState({});
  const[sending,setSending]=useState(false);
  const[result,setResult]=useState(null);
  var step=STEPS[active];

  useEffect(function(){setData({});setResult(null);},[active]);

  var handleSubmit=async function(){
    setSending(true);setResult(null);
    var payload=Object.assign({formulario:step.id,timestamp:new Date().toISOString()},data);
    try{
      await fetch(GOOGLE_SCRIPT_URL,{method:"POST",mode:"no-cors",headers:{"Content-Type":"application/json"},body:JSON.stringify(payload)});
      setResult({ok:true});setData({});
    }catch(err){setResult({ok:false,msg:err.message});}
    setSending(false);
  };

  var forms={solicitudes:<F1 d={data} s={setData}/>,programacion:<F2 d={data} s={setData}/>,recoleccion:<F3 d={data} s={setData}/>,descargue:<F4 d={data} s={setData}/>,cierre:<F5 d={data} s={setData}/>};

  return(
    <div style={{minHeight:"100vh",background:"linear-gradient(160deg,#0c1222 0%,#162033 50%,#0f1729 100%)",fontFamily:ft}}>

      {/* HEADER */}
      <div style={{background:"rgba(12,18,34,0.92)",borderBottom:"1px solid rgba(255,255,255,0.06)",padding:"14px 20px",display:"flex",alignItems:"center",justifyContent:"space-between",backdropFilter:"blur(12px)"}}>
        <div style={{display:"flex",alignItems:"center",gap:11}}>
          <div style={{width:36,height:36,borderRadius:10,background:"linear-gradient(135deg,#3b82f6,#8b5cf6)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:17}}>📦</div>
          <div>
            <h1 style={{color:"#f1f5f9",fontSize:15,fontWeight:700,margin:0}}>Control de Devoluciones</h1>
            <p style={{color:"#64748b",fontSize:10,margin:0,fontFamily:mn,letterSpacing:"0.05em"}}>SISTEMA UNIFICADO</p>
          </div>
        </div>
        <div style={{background:"rgba(255,255,255,0.05)",borderRadius:8,padding:"5px 11px",fontSize:11,color:"#94a3b8",fontFamily:mn}}>
          {new Date().toLocaleDateString("es-CO",{weekday:"short",year:"numeric",month:"short",day:"numeric"})}
        </div>
      </div>

      {/* TABS */}
      <div style={{display:"flex",gap:2,padding:"16px 16px 0",maxWidth:740,margin:"0 auto",overflowX:"auto"}}>
        {STEPS.map(function(st,idx){var on=idx===active;return(
          <button key={st.id} onClick={function(){setActive(idx)}} style={{flex:1,minWidth:56,padding:"10px 4px",background:on?"rgba(255,255,255,0.08)":"transparent",border:"none",borderBottom:on?"3px solid "+st.c:"3px solid transparent",cursor:"pointer",borderRadius:"10px 10px 0 0",transition:"all 0.2s",display:"flex",flexDirection:"column",alignItems:"center",gap:3}}>
            <span style={{fontSize:18}}>{st.i}</span>
            <span style={{fontSize:9,fontWeight:on?700:500,color:on?"#f1f5f9":"#64748b",fontFamily:mn}}>{st.n}</span>
            <span style={{fontSize:11,fontWeight:on?600:400,color:on?"#f1f5f9":"#94a3b8",fontFamily:ft,whiteSpace:"nowrap"}}>{st.l}</span>
          </button>
        );})}
      </div>

      {/* CARD */}
      <div style={{maxWidth:740,margin:"0 auto",padding:"0 16px 40px"}}>
        <div style={{background:"#fff",borderRadius:"0 0 20px 20px",boxShadow:"0 20px 50px rgba(0,0,0,0.25)",overflow:"hidden"}}>
          <div style={{background:"linear-gradient(135deg,"+step.c+"12,"+step.c+"06)",borderBottom:"1px solid "+step.c+"20",padding:"18px 24px",display:"flex",alignItems:"center",gap:12}}>
            <div style={{width:42,height:42,borderRadius:12,background:step.c+"12",border:"1.5px solid "+step.c+"25",display:"flex",alignItems:"center",justifyContent:"center",fontSize:20}}>{step.i}</div>
            <div>
              <h2 style={{margin:0,fontSize:17,fontWeight:700,color:"#0f172a"}}>{step.n} — {step.l}</h2>
              <p style={{margin:0,fontSize:12,color:"#64748b",marginTop:1}}>{step.d}</p>
            </div>
          </div>

          <div style={{padding:"22px 24px"}}>
            {forms[step.id]}

            {result&&<div style={{padding:"12px 16px",borderRadius:12,marginBottom:14,background:result.ok?"#f0fdf4":"#fef2f2",border:result.ok?"1px solid #bbf7d0":"1px solid #fecaca",display:"flex",alignItems:"center",gap:10}}>
              <span style={{fontSize:17}}>{result.ok?"✅":"❌"}</span>
              <span style={{fontSize:13,color:result.ok?"#166534":"#991b1b",fontWeight:500}}>{result.ok?"Registro enviado exitosamente a Google Sheets":"Error: "+result.msg}</span>
            </div>}

            <button onClick={handleSubmit} disabled={sending} style={{width:"100%",padding:"13px 24px",color:"#fff",border:"none",borderRadius:12,fontSize:15,fontWeight:700,cursor:sending?"not-allowed":"pointer",fontFamily:ft,background:sending?"#94a3b8":"linear-gradient(135deg,"+step.c+","+step.c+"cc)",boxShadow:sending?"none":"0 4px 14px "+step.c+"35",transition:"all 0.2s",display:"flex",alignItems:"center",justifyContent:"center",gap:8}}>
              {sending?<span>Enviando...</span>:<span>Enviar {step.l}</span>}
            </button>
          </div>
        </div>
        <p style={{textAlign:"center",marginTop:16,fontSize:11,color:"#475569",fontFamily:mn,lineHeight:1.6}}>⚙️ Reemplaza GOOGLE_SCRIPT_URL con tu URL de Apps Script</p>
      </div>
    </div>
  );
}

ReactDOM.render(<App/>, document.getElementById("root"));
</script>
</body>
</html>
