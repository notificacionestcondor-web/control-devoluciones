  return(<div>
    <Fd label="ID Solicitud" req><Ti value={d.id_sol} onChange={function(v){u("id_sol",v)}} placeholder="DEV-2026-000001"/></Fd>
    <R2><Fd label="Fecha real recolección" req><Ti type="date" value={d.fecha_rec} onChange={function(v){u("fecha_rec",v)}}/></Fd><Fd label="Hora" req><Ti type="time" value={d.hora_rec} onChange={function(v){u("hora_rec",v)}}/></Fd></R2>
    <R2><Fd label="Ciudad" req><Si value={d.ciudad} onChange={function(v){u("ciudad",v)}} options={CIUDADES}/></Fd><Fd label="Tienda" req><SS value={d.tienda} onChange={function(v){u("tienda",v)}} options={TIENDAS} placeholder="Buscar tienda..."/></Fd></R2>
    <R2><Fd label="Persona que entrega" req><Ti value={d.p_entrega} onChange={function(v){u("p_entrega",v)}} placeholder="Nombre"/></Fd><Fd label="Persona que recibe (Condor)" req><Ti value={d.p_recibe} onChange={function(v){u("p_recibe",v)}} placeholder="Nombre"/></Fd></R2>
    <Fd label="Placa vehículo Condor" req><Ti value={d.placa} onChange={function(v){u("placa",v)}} placeholder="Ej: NOL 404"/></Fd>
    <Fd label="Cantidades recolectadas" req hint="Selecciona productos recolectados"><Ps options={PRODUCTOS} selected={d.prods} onChange={function(v){u("prods",v)}} multi={true}/></Fd>
    {d.prods&&d.prods.length>0&&<Fd label="Cantidades"><QF productos={d.prods} data={d} onChange={s}/></Fd>}
    <Fd label="¿Existen diferencias?" req><Ps options={["SI","NO"]} selected={d.dif} onChange={function(v){u("dif",v)}}/></Fd>
    {d.dif==="SI"&&<Fd label="Descripción diferencias" req><Ta value={d.desc_dif} onChange={function(v){u("desc_dif",v)}} placeholder="Describe las diferencias..."/></Fd>}
    <Fd label="Fotos" req hint="Hasta 5 archivos (PDF o imagen, máx 10 MB c/u)"><input type="file" multiple accept="image/*,.pdf" style={Object.assign({},bI,{padding:"8px 12px",cursor:"pointer"})}/></Fd>
    <Fd label="OK funcionario Condor" req><Ps options={["SI","NO"]} selected={d.ok_cond} onChange={function(v){u("ok_cond",v)}}/></Fd>
    <Fd label="Observaciones" req><Ta value={d.obs} onChange={function(v){u("obs",v)}} placeholder="Observaciones..."/></Fd>
