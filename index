function F5({d,s}){
  var u=function(k,v){var nd=Object.assign({},d);nd[k]=v;s(nd);};
  return(<div>
    <Fd label="ID Solicitud" req hint="DEV-2026-XXXXXX"><Ti value={d.id_sol} onChange={function(v){u("id_sol",v)}} placeholder="DEV-2026-000001"/></Fd>
